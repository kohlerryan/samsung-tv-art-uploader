# ─────────────────────────────────────────────────────────────────────────────
# samsung-tv-art.env — copy this file to samsung-tv-art.env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Samsung Frame TV ─────────────────────────────────────────────────────────

# IP address of your Samsung Frame TV (required)
SAMSUNG_TV_ART_TV_IP=10.0.0.10

# How often (minutes) to rotate to the next artwork (0 = disabled)
SAMSUNG_TV_ART_UPDATE_MINUTES=30

# Maximum number of images to keep uploaded on the TV at once
SAMSUNG_TV_ART_MAX_UPLOADS=30

# true = cycle artwork in a fixed alphabetical order; false = random shuffle
SAMSUNG_TV_ART_SEQUENTIAL=false

# How often (seconds) the uploader polls for file/collection changes
SAMSUNG_TV_ART_CHECK_SECONDS=5

# How often (seconds) to poll the TV to detect Art Mode on/off changes.
# Lower = faster UI response when toggling Art Mode on/off. Default: 5.
# ⚠ If you previously set this to a high value (e.g. 600), remove it or lower
#   it — otherwise the web UI and HA card will be slow to react to Art Mode changes.
SAMSUNG_TV_ART_MODE_CHECK_SECONDS=5

# How often (seconds) to republish the current artwork state to MQTT even if
# nothing has changed (keeps HA entities fresh after a broker restart). Default: 300.
# SAMSUNG_TV_ART_STATE_REFRESH_SECONDS=300

# ── Artwork paths (usually leave as defaults) ─────────────────────────────────

SAMSUNG_TV_ART_ART_DIR=/app/frame_tv_art_collections
SAMSUNG_TV_ART_MEDIA_ROOT=/app/frame_tv_art_collections
SAMSUNG_TV_ART_STANDBY_FILE=/app/frame_tv_art_collections/standby.png

# Path to the uploaded-files cache (persists upload history across restarts)
# SAMSUNG_TV_ART_CACHE_FILE=/data/uploaded_files_cache.json

# ── Git collection sources ────────────────────────────────────────────────────
# Space- or comma-separated list of git repository URLs to fetch on startup
# or when "Update & Refresh" is triggered. Leave blank to use only the local
# media bind-mount (./media → /app/frame_tv_art_collections).
# Append #branch to pin to a specific branch, e.g. https://github.com/you/repo.git#main
#
# SAMSUNG_TV_ART_COLLECTIONS=https://github.com/you/Claude_Monet.git https://github.com/you/Edgar_Degas.git

# GitHub personal access token — required for private repos; also avoids
# rate limits on large collection sets. Grant `repo` read scope (+ SSO if org-managed).
# SAMSUNG_TV_ART_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Fetch collections from git on container startup (default: false — fetch on-demand via UI)
SAMSUNG_TV_ART_FETCH_ON_START=false

# ── CSV / artwork metadata ────────────────────────────────────────────────────

# Use artwork_data.csv inside each collection folder to show friendly artist/
# collection names in the UI dropdown instead of raw folder names (default: true).
SAMSUNG_TV_ART_COLLECTIONS_FROM_CSV=true

# Path to the merged artwork_data.csv (generated by scripts/aggregate_csv.py)
# SAMSUNG_TV_ART_CSV_PATH=/app/artwork_data.csv

# How often (seconds) to re-check the CSV for changes (default: 60)
# SAMSUNG_TV_ART_CSV_CHECK_SECONDS=60

# Seconds to wait for the CSV to appear on startup before proceeding (default: 120)
# SAMSUNG_TV_ART_WAIT_FOR_CSV_SECONDS=120

# If true (default), abort startup if CSV is expected but missing.
# Set to false to start without CSV metadata (raw folder names will be used).
# SAMSUNG_TV_ART_REQUIRE_CSV_ON_START=true

# ── Collection selection ──────────────────────────────────────────────────────

# MQTT topic from which the uploader reads the active collection selection
# (default: frame_tv/selected_collections/state)
# SAMSUNG_TV_ART_SELECTION_MQTT_TOPIC=frame_tv/selected_collections/state

# If true, the uploader will only react to selection changes via MQTT and will
# not upload or rotate artwork on its own timer (default: false)
# SAMSUNG_TV_ART_SELECTION_ONLY=false

# ── Upload timing ─────────────────────────────────────────────────────────────

# Delay (seconds) between individual image uploads to avoid overwhelming the TV (default: 1)
# SAMSUNG_TV_ART_UPLOAD_DELAY_SECONDS=1

# Delay (seconds) between individual image deletions (default: 1)
# SAMSUNG_TV_ART_DELETE_DELAY_SECONDS=1

# Seconds to wait after all deletions finish before uploading new images (default: 5)
# Increase if uploads fail after a refresh (TV needs more recovery time)
# SAMSUNG_TV_ART_POST_DELETE_RECOVERY_SECONDS=5

# ── MQTT ─────────────────────────────────────────────────────────────────────
# Setting SAMSUNG_TV_ART_MQTT_HOST enables MQTT. SAMSUNG_TV_ART_MQTT_DISCOVERY
# is optional — only needed to auto-create entities in Home Assistant.

SAMSUNG_TV_ART_MQTT_HOST=10.0.0.5
SAMSUNG_TV_ART_MQTT_PORT=1883
SAMSUNG_TV_ART_MQTT_USERNAME=youruser
SAMSUNG_TV_ART_MQTT_PASSWORD=yourpass

# Uncomment to enable Home Assistant MQTT Discovery (auto-creates HA entities)
# SAMSUNG_TV_ART_MQTT_DISCOVERY=true
SAMSUNG_TV_ART_MQTT_DISCOVERY_PREFIX=homeassistant

# Override the default MQTT client ID (default: auto-generated from hostname)
# SAMSUNG_TV_ART_MQTT_CLIENT_ID=samsung-tv-art

# ── MQTT topics (override only if you have conflicts) ─────────────────────────

# SAMSUNG_TV_ART_MQTT_STATE_TOPIC=frame_tv/selected_artwork/state
# SAMSUNG_TV_ART_MQTT_ATTR_TOPIC=frame_tv/selected_artwork/attributes
# SAMSUNG_TV_ART_MQTT_UNIQUE_ID=frame_tv_art_selected_artwork
# SAMSUNG_TV_ART_MQTT_CMD_PREFIX=frame_tv/cmd
# SAMSUNG_TV_ART_MQTT_ACK_PREFIX=frame_tv/ack
# SAMSUNG_TV_ART_MQTT_COLLECTIONS_STATE=frame_tv/collections/state
# SAMSUNG_TV_ART_MQTT_COLLECTIONS_ATTR=frame_tv/collections/attributes
# SAMSUNG_TV_ART_MQTT_COLLECTIONS_UNIQUE_ID=frame_tv_art_collections
# SAMSUNG_TV_ART_MQTT_SELECTED_COLLECTIONS_STATE=frame_tv/selected_collections/summary
# SAMSUNG_TV_ART_MQTT_SELECTED_COLLECTIONS_ATTR=frame_tv/selected_collections/attributes
# SAMSUNG_TV_ART_MQTT_SETTINGS_STATE=frame_tv/settings/state
# SAMSUNG_TV_ART_MQTT_SETTINGS_ATTR=frame_tv/settings/attributes
# SAMSUNG_TV_ART_MQTT_SLIDESHOW_STATE=frame_tv/slideshow/state
# SAMSUNG_TV_ART_MQTT_SLIDESHOW_ATTR=frame_tv/slideshow/attributes
# SAMSUNG_TV_ART_MQTT_SLIDESHOW_AVAILABLE=frame_tv/slideshow/available

# ── Web UI ────────────────────────────────────────────────────────────────────

# Enable the built-in web UI (default: true)
SAMSUNG_TV_ART_LOCAL_WEB=true

# Friendly hostname used in the web UI title and mDNS advertisement
SAMSUNG_TV_ART_PUBLIC_HOSTNAME=samsung-tv-art

# Set to true ONLY on a trusted LAN — exposes MQTT password in the browser UI
SAMSUNG_TV_ART_LOCAL_WEB_EXPOSE_PASSWORD=false

# WebSocket port for MQTT (used by the browser-based web UI, default: 9001)
# SAMSUNG_TV_ART_MQTT_WS_PORT=9001

# ── mDNS (.local) ─────────────────────────────────────────────────────────────
# Advertises the web UI as samsung-tv-art.local:8080 via Avahi (requires
# multicast DNS on your network; works automatically on macOS / iOS).

SAMSUNG_TV_ART_MDNS_ENABLE=true

# ── Older Frame TV compatibility ─────────────────────────────────────────────
# The 2019 Frame TV (and possibly other older models) rejects uploads over ~1 MB
# with error -1. Set this to enforce a maximum encoded file size in bytes; images
# larger than this threshold will be progressively JPEG-compressed until they fit.
# Unset by default — no recompression on modern TVs.
# Recommended value for 2019 models: 900000 (~900 KB)
# SAMSUNG_TV_ART_MAX_FILE_BYTES=900000

# ── Advanced / optional ───────────────────────────────────────────────────────

# Enable verbose debug logging (default: false)
# SAMSUNG_TV_ART_DEBUG=true

# Path to the TV authentication token file (persists across restarts)
# SAMSUNG_TV_ART_TOKEN_FILE=/data/token_file.txt

# How often (seconds) to log memory usage (0 = disabled, default: 0)
# SAMSUNG_TV_ART_MEMLOG_SECONDS=60
